# ── LLM 解説機能（任意） ─────────────────────────────────
# 「不可」理由の自然言語解説の生成にのみ使用します。判定そのものには一切使いません。
# 未設定でもアプリは動作し、解説はルールベースのフォールバック文に切り替わります。
ANTHROPIC_API_KEY=

# 解説生成に使うモデル（既定: claude-sonnet-4-6）
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Supabase（任意 / 将来の永続化） ───────────────────────
# 未設定の場合はローカル JSON（data/standards.ts）をデータ源として動作します。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
